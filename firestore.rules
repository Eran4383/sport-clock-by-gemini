rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Exercise Cache: 
    // Readable by anyone (so users can see exercise info without login if needed)
    // Writable by anyone for now (since the API runs as an unauthenticated client)
    // In a production app, we'd restrict writes to a service account, but for this 
    // serverless setup, we allow it with validation.
    match /exercise_cache/{exerciseId} {
      allow read: if true;
      allow write: if true; // The API handler will write here
    }

    // User Data: Only the owner can read/write
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /plans/{planId} {
        allow read, write: if isOwner(userId);
      }
      
      match /history/{logId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
