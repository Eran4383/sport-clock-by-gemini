{
  "entities": {
    "ExerciseCache": {
      "title": "Exercise Cache",
      "description": "Cached exercise information including instructions, tips, and video IDs.",
      "type": "object",
      "properties": {
        "instructions": { "type": "string" },
        "tips": { "type": "array", "items": { "type": "string" } },
        "generalInfo": { "type": "string" },
        "language": { "type": "string" },
        "primaryVideoId": { "type": "string" },
        "alternativeVideoIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["instructions", "tips", "generalInfo", "language"]
    },
    "User": {
      "title": "User Profile",
      "description": "User specific data and settings.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" }
      }
    }
  },
  "firestore": {
    "exercise_cache/{exerciseId}": {
      "schema": "ExerciseCache",
      "description": "Global cache for exercise information."
    },
    "users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    }
  }
}
